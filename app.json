{
  "expo": {
    "name": "RemindApp",
    "slug": "remind-app",
    "scheme": "remind-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logoreminder_main.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F9F9F9"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.remindapp.app",
      "infoPlist": {
        "NSUserNotificationUsageDescription": "Ứng dụng cần quyền thông báo để nhắc lịch công việc của bạn."
      }
    },
    "android": {
      "package": "com.remindapp.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logoreminder_foreground.png",
        "backgroundColor": "#E3F2FD"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "android.permission.SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/logoreminder_foreground.png",
          "color": "#1A73E8",
          "defaultChannel": "reminders",
          "sounds": []
        }
      ],
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "539e65f2-0e38-4cae-bfeb-963833635167"
      }
    }
  }
}
